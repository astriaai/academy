# webinar-builder environment
#
# Local dev: copy to `.env` — dotenv/config loads it automatically.
# CI: these are GitHub Actions repo secrets, passed to the build job as `env:`.
#     dotenv/config no-ops cleanly when `.env` is absent.
#
# A build is fully free with DRAFT=1 (silent placeholder audio, no paid APIs).
# Real narration / avatars / video need the keys below — but every generator
# caches its result by content hash, so an unchanged segment never re-pays.

# ─── TTS (narration) ────────────────────────────────────────────────────────
# Google Gemini TTS — default narration path (TTS_PROVIDER=gemini).
VERTEX_API_KEY=

# WaveSpeed — Inworld TTS + OmniHuman / InfiniteTalk avatar lipsync.
WAVESPEED_API_KEY=

# HeyGen Avatar IV — stock avatar + native voice fallback.
# https://app.heygen.com/settings/api
HEYGEN_API_KEY=
# Optional: override avatar + voice (otherwise from script/projects/<name>.yaml)
# HEYGEN_AVATAR_ID=Daisy-inskirt-20220818
# HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad5158bc8

# ─── Avatar engines (optional, per-segment avatar.engine) ───────────────────
# BytePlus OmniHuman 1.5 — used when avatar.engine: omnihuman-1.5-byteplus
BYTEPLUS_ACCESS_KEY_ID=
BYTEPLUS_SECRET_ACCESS_KEY=

# Replicate — Pruna p-video-avatar, used when avatar.engine: pruna
# REPLICATE_API_KEY=

# ─── Astria (Seedance video generation) ─────────────────────────────────────
ASTRIA_AUTH_TOKEN=
# Astria tune used for Gemini / Seedance generation (required for video).
GEMINI_TUNE_ID=
# Optional overrides
# ASTRIA_BASE_URL=https://api.astria.ai
# WORKSPACE_ID=
# SEEDREAM_TUNE_ID=
# RECRAFT_TUNE_ID=

# ─── Behavior flags (no key needed — set inline or in CI) ───────────────────
# DRAFT=1          skip all paid APIs: silent audio + burned-in captions
# NO_AVATAR=1      skip talking-head generation
# NO_SCREENCAST=1  skip Playwright screencast recording (auto-on when CI is set)
# TTS_PROVIDER=    gemini | inworld — overrides the project default
# HF_WORKERS=      hyperframes render worker count (default 2/4)
